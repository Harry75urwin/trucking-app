# Backend Configuration
APP_NAME=Learning Trucking API
APP_DESCRIPTION=API documentation for the trucking platform
APP_VERSION=1.0
APP_PORT=3000
SWAGGER_PATH=docs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
AUTH_SECRET=change-this-secret
AUTH_TOKEN_TTL_SECONDS=86400
DEMO_DATA_ENABLED=true

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=truckuser
DB_PASSWORD=truckpass
DB_DATABASE=truckapp

# LocalStack S3 (for local file uploads)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_S3_BUCKET=truck-app-bucket
S3_ENDPOINT=http://localhost:4566
S3_PUBLIC_URL=http://localhost:4566/truck-app-bucket